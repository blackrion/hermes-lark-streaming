# E2E test environment variables (copy to tests/e2e/.env and fill in)
#
# When ALL THREE variables below are set, tests/e2e/ runs against the
# REAL Feishu API (creates actual cards in your Feishu app).
# When any is missing, tests use the in-memory mock server.
#
# Test code is IDENTICAL in both modes — only the underlying client differs.
#
# WARNING: Real Feishu e2e tests create actual cards visible to users
# in the specified chat. Use a dedicated TEST bot and TEST group,
# NOT your production bot.

# ── Required for real mode (all 3 must be set) ──

# 1. FEISHU_E2E_APP_ID — 飞书应用 App ID
#    获取方式：
#    a. 登录飞书开放平台 https://open.feishu.cn/app
#    b. 创建一个新应用（或用现有测试应用）
#    c. 在"凭证与基础信息"页面找到 App ID
#    d. 确保应用已开启"机器人"能力
#    e. 确保应用已添加权限：im:message, im:message:send_as_bot,
#       cardkit:card, cardkit:card:streaming（或更宽泛的 im:message:group_at_msg）
FEISHU_E2E_APP_ID=

# 2. FEISHU_E2E_APP_SECRET — 飞书应用 App Secret
#    获取方式：同上，在"凭证与基础信息"页面找到 App Secret
#    （点击"显示"按钮复制）
FEISHU_E2E_APP_SECRET=

# 3. FEISHU_E2E_CHAT_ID — 测试群的 chat_id
#    获取方式（任选其一）：
#
#    方式 A（推荐）：用 bot 的 webhook 事件
#    a. 把测试 bot 加入一个测试群
#    b. 在群里 @bot 发一条消息
#    c. 在飞书开放平台 → 你的应用 → "事件订阅"页面查看事件日志
#    d. 找到 message.receive 事件，payload 里的 event.message.chat_id 就是
#
#    方式 B：用 API 列出群
#    a. 确保应用有 im:chat:readonly 权限
#    b. 调用 GET https://open.feishu.cn/open-apis/im/v1/chats
#       （用 tenant_access_token）
#    c. 响应里的 data.items[].chat_id 就是
#
#    方式 C：从群链接推算（不可靠，不推荐）
#    chat_id 不能从群链接直接推算，必须用上述 API 获取
FEISHU_E2E_CHAT_ID=

# ── Optional ──

# Feishu API base URL（国内版默认，国际版用 https://open.larksuite.com/open-apis）
FEISHU_E2E_BASE_URL=https://open.feishu.cn/open-apis

# ── 运行方式 ──
#
# 本地真飞书模式：
#   1. 复制本文件到 tests/e2e/.env
#   2. 填入 3 个必填值
#   3. 运行：
#      set -a && source tests/e2e/.env && set +a
#      python -m pytest tests/e2e/ -v
#
# 本地 mock 模式（默认，无需配置）：
#   python -m pytest tests/e2e/ -v
#
# 强制 mock 模式（即使 .env 存在）：
#   unset FEISHU_E2E_APP_ID FEISHU_E2E_APP_SECRET FEISHU_E2E_CHAT_ID
#   python -m pytest tests/e2e/ -v
#
# ── 真飞书模式工作原理 ──
#
# runner.setup() 时会自动：
#   1. 用 App ID/Secret 创建 FeishuClient
#   2. 向测试群发一条文本消息 "[e2e test anchor HH:MM:SS]"
#   3. 拿到这条消息的 message_id 作为 anchor
#   4. 后续测试创建的卡片都 reply 到这个 anchor
#
# 所以你只需要提供 App ID、App Secret、Chat ID 三个值，
# 不需要手动获取 message_id。
