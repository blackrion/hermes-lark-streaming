{
  "schema": "2.0",
  "config": {
    "wide_screen_mode": true,
    "streaming_mode": false,
    "locales": [
      "zh_cn",
      "en_us"
    ]
  },
  "body": {
    "elements": [
      {
        "tag": "div",
        "icon": {
          "tag": "standard_icon",
          "token": "info_outlined",
          "size": "20px 20px",
          "color": "blue"
        },
        "text": {
          "tag": "lark_md",
          "content": "**请选择执行方式**"
        }
      },
      {
        "tag": "markdown",
        "content": "A. 自动执行\nB. 手动确认"
      },
      {
        "tag": "select_static",
        "element_id": "clarify_select",
        "placeholder": {
          "tag": "plain_text",
          "content": "Quick select...",
          "i18n_content": {
            "zh_cn": "快速选择...",
            "en_us": "Quick select..."
          }
        },
        "options": [
          {
            "text": {
              "tag": "plain_text",
              "content": "A. 自动执行"
            },
            "value": "0"
          },
          {
            "text": {
              "tag": "plain_text",
              "content": "B. 手动确认"
            },
            "value": "1"
          }
        ],
        "behaviors": [
          {
            "type": "callback",
            "value": {
              "hermes_clarify_action": "select",
              "clarify_id": "test-123"
            }
          }
        ]
      },
      {
        "tag": "input",
        "element_id": "clarify_input",
        "placeholder": {
          "tag": "plain_text",
          "content": "Type your answer...",
          "i18n_content": {
            "zh_cn": "请输入你的回答...",
            "en_us": "Type your answer..."
          }
        },
        "max_length": 500,
        "name": "clarify_input",
        "behaviors": [
          {
            "type": "callback",
            "value": {
              "hermes_clarify_action": "input_submit",
              "clarify_id": "test-123"
            }
          }
        ]
      }
    ]
  }
}